<Window x:Class="Projekt_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_wpf"
        mc:Ignorable="d"
        Title="Termékek" Height="500" Width="860">
    <Grid>
        <Menu>
            <MenuItem Header="_Fájl">
                <MenuItem x:Name="miSaveAs" Header="Mentés másként" Click="btnMent_Click"/>
                <MenuItem x:Name="miExit" Header="Kilépés" Click="btnKilep_Click" InputGestureText="Esc"/>
            </MenuItem>
            <MenuItem Header="Súgó">
                <MenuItem x:Name="miAbout" Header="Névjegy" Click="btnNevjegy_Click" />
                <!--<MenuItem x:Name="miWeb" Header="Online" Click="btnWeb_Click" />-->
            </MenuItem>
        </Menu>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <DataGrid x:Name="dtgAdatok" Margin="20" ColumnWidth="*"/>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="1">
                    <Button x:Name="btnFelvisz" Content="Felvitel" HorizontalAlignment="Center" Margin="0 20" Click="btnFelvisz_Click"/>
                    <Button x:Name="btnModosit" Content="Módosítás" HorizontalAlignment="Center" Margin="0 20" Click="btnModosit_Click"/>
                    <Button x:Name="btnTorol" Content="Törlés" HorizontalAlignment="Center" Margin="0 20" Click="btnTorol_Click"/>
                    <StackPanel Orientation="Horizontal" Margin="0 40 0 0">
                        <Button x:Name="btnMent" Content="Mentés" Margin="20" Click="btnMent_Click"/>
                        <Button x:Name="btnBetolt" Content="Betöltés" Margin="20" Click="btnBetolt_Click"/>
                    </StackPanel>
                </StackPanel>
                <Button x:Name="btnKilep" Grid.Row="1" Content="Kilép" HorizontalAlignment="Center" VerticalAlignment="Top" Click="btnKilep_Click" IsCancel="True"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
