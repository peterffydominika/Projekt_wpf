<Window x:Class="Projekt_wpf.Modositas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Projekt_wpf"
        mc:Ignorable="d"
        Title="Módosítás" Height="600" Width="300" FontSize="18">
    <Grid>
        <WrapPanel Orientation="Vertical" Margin="0, 20,0, 0">
            <Label Content="ID (nem módosítható):" Grid.Row="0"/>
            <TextBox x:Name="tbxId" IsReadOnly="True" Width="250" Margin="10"/>
            <Label Content="Alkategória id:" Grid.Row="0"/>
            <TextBox x:Name="tbxAlkategoriaId" Width="250" Margin="10"/>
            <Label Content="Név:"/>
            <TextBox x:Name="tbxNev" Width="250" Margin="10"/>
            <Label Content="Ár:"/>
            <TextBox x:Name="tbxAr" Width="250" Margin="10"/>
            <Label Content="Akciós ár:"/>
            <TextBox x:Name="tbxAkciosAr" Width="250" Margin="10"/>
            <Label Content="Készlet:"/>
            <TextBox x:Name="tbxKeszlet" Width="250" Margin="10"/>
            <Button x:Name="btnOk" Content="OK" Margin="10" Click="btnOk_Click"/>
        </WrapPanel>
    </Grid>
</Window>